# AxoloDAO Backend Relayer — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to git!

# Private key of the RELAYER_WALLET (EOA that pays gas)
# This wallet must be the trustedForwarder in all 3 contracts
RELAYER_PRIVATE_KEY=0x4b87b9d45192a915228c0f68c5749a3e86a5e793a60476b7bc6d7fd96e5afd84

# Sepolia RPC URL (Alchemy or Infura)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/3EiMWpRc_XHmAgaZRYUV6

# Contract addresses (update after redeploy)
ACCESS_CONTRACT=0xd622b7ca9618b1bdf031af5a6caf34c19f6aa0a2
REGISTRY_CONTRACT=0xdf5eff5019c2177ca752549ecaf6df1f2c297b12
MONITORING_CONTRACT=0x938c0c6ee0b4a6e96ff862f89ddf05116dce8e24

# Server port
PORT=3000
